---
import type { HTMLTag } from 'astro/types'
import Link from './link.astro'

export interface AttributionProps {
  as?: HTMLTag
  class?: string
}

const { as: Tag = 'footer', class: extraClass }: AttributionProps = Astro.props
---

<Tag class={extraClass}>
  Challenge by
  <Link
    external
    class="inline-block hover:underline"
    to="https://www.frontendmentor.io/challenges"
    style={{ color: '#3E54A3' }}
  >
    Frontend Mentor
  </Link>. Coded by
  <Link external to="https://erian.dev" class="inline-block font-semibold hover:underline" style={{ color: '#02ABB1' }}>
    eriandev
  </Link>
</Tag>
