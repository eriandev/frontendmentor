---
import { get } from 'shared/utils/http'
import type { PictureProps } from 'shared/components/picture.astro'

import Card from '@/components/card.astro'
import Layout from '@/app.astro'

export interface Projects {
  level: {
    link: string
    name: string
    number: number
  }
  link: string
  title: string
  techs: string[]
  description: string
  picture: PictureProps
}

const { results } = await get<{ results: Projects[] }>(import.meta.env.PUBLIC_API_URL + '/projects/')
const hasProjects = results.length > 0
---

<Layout title="Frontendmentor Challenges Solved">
  <section class="border-y border-y-gray-300">
    <div class="mx-auto flex w-full max-w-300 px-6 tracking-[0.2em] xl:px-0">
      <article class="w-max border-x border-x-gray-300 px-6 py-4 font-bold uppercase">My Solutions</article>
    </div>
  </section>

  <main
    class:list={[
      'mx-auto max-w-3xl xl:max-w-300',
      { 'flex h-main items-center': !hasProjects },
      { 'grid grid-cols-1 gap-6.5 px-6 py-16 sm:grid-cols-2 xl:grid-cols-3 xl:px-0': hasProjects },
    ]}
  >
    {
      hasProjects ? (
        results.map(({ picture, ...project }, index) => {
          const fetchpriority = index < 6 ? 'high' : undefined
          return <Card {...project} picture={{ ...picture, fetchpriority, lazy: fetchpriority !== 'high' }} />
        })
      ) : (
        <p class="mx-auto w-max text-2xl md:text-3xl">No projects to show...</p>
      )
    }
  </main>
</Layout>
