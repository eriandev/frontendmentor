{
  "name": "countries-api-with-color-theme-switcher",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "astro": "astro",
    "dev": "astro dev",
    "preview": "astro preview",
    "clean": "rm -rf node_modules dist",
    "reset": "pnpm clean && rm -rf .astro",
    "check": "astro check --tsconfig tsconfig.json",
    "format": "prettier --write src/**/*.{astro,svelte,ts,css}",
    "build": "mkdir -p ../../dist/countries-api-with-color-theme-switcher && cp -r dist/. ../../dist/countries-api-with-color-theme-switcher/"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "devDependencies": {
    "shared": "workspace:*"
  }
}