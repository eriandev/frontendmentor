---
import BaseLayout from 'shared/components/base-layout.astro'
import Header from '@/components/header.astro'
import '@/app.css'

interface Props {
  bodyClass?: string
}

const { bodyClass } = Astro.props

const slug = 'countries-api-with-color-theme-switcher'
const projectName = 'REST Countries API with color theme switcher'
const attribution = {
  class:
    'fixed right-0 bottom-0 left-0 mx-auto w-max rounded-t-lg bg-light-mode p-1 text-center text-xs font-semibold dark:bg-dark-mode',
}
const body = {
  'class:list': [
    'relative min-h-screen bg-light-mode font-nunito-sans text-light-mode-text dark:bg-dark-mode dark:text-white',
    bodyClass,
  ],
}
const description =
  "If you're wanting to test your JavaScript skills this is the challenge for you. Use whichever JS framework you prefer and pull data from the REST Countries API."
---

<BaseLayout withTransitions {body} {attribution} {projectName} {description} {slug}>
  <Fragment slot="head">
    <script is:inline>
      const applyTheme = () => {
        const theme = localStorage.getItem('theme')
        if (theme === 'dark') document.documentElement.classList.add('dark')
        else document.documentElement.classList.remove('dark')
      }

      applyTheme()
      document.addEventListener('astro:after-swap', applyTheme)
    </script>

    <slot name="head" />
  </Fragment>

  <Header />
  <slot />
</BaseLayout>
