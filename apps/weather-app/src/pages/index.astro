---
import Layout from '@/app.astro'
import Header from '@/components/header.astro'
import Content from '@/components/content.svelte'
import Atributtion from 'shared/components/atributtion.astro'
import SearchSection from '@/components/search-section.svelte'
---

<Layout>
  <Header />

  <main class="mx-auto grid max-w-6xl gap-y-8 px-5 py-12 lg:gap-y-12">
    <header class="grid gap-y-12">
      <h1 class="text-center font-bricolage-grotesque text-5xl font-bold text-white">How's the sky looking today?</h1>
      <SearchSection client:idle />
    </header>

    <Content client:idle />
  </main>

  <Atributtion class="mx-auto pb-6 text-center text-sm text-white" />
</Layout>
