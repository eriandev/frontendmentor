---
import BaseLayout from 'shared/components/base-layout.astro'
import '@/app.css'

const slug = 'interactive-card-details-form'
const projectName = 'Interactive card details form'
const attribution = {
  class: 'mx-auto max-w-60 pb-8 text-center text-sm sm:pb-4 lg:hidden',
}
const body = {
  class: 'min-h-screen font-space-grotesk',
}
const description =
  'This fun project will be an excellent way to practice DOM manipulation and form validation while also putting your HTML and CSS skills to the test.'
---

<BaseLayout {body} {attribution} {projectName} {description} {slug} themeColor="#600594">
  <Fragment slot="head">
    <script src="@/scripts/declare-refs.ts"></script>
    <script src="@/scripts/update-cards.ts"></script>
    <script src="@/scripts/validate-inputs.ts"></script>
    <script src="@/scripts/form-handler.ts"></script>
  </Fragment>

  <slot />
</BaseLayout>
