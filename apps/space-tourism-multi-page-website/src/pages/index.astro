---
import Link from 'shared/components/link.astro'
import { basePath } from '@/utils/consts'
import Layout from '@/app.astro'
---

<Layout
  navKey="home"
  withoutAtributtion
  bodyClass="bg-home-mobile bg-center bg-cover md:bg-home-tablet lg:bg-home-desktop"
>
  <main
    class="grid grid-rows-[fit-content(100%)_auto] p-6 text-center md:px-10 md:py-32 xl:min-h-[calc(100dvh-8.5rem)] xl:grid-cols-[repeat(2,fit-content(100%))] xl:grid-rows-1 xl:items-end xl:justify-between xl:px-40 xl:py-32 xl:text-left"
  >
    <section>
      <span class="font-barlow-condensed text-blue-300 uppercase md:text-[1.75rem]">So, you want to travel to</span>
      <h1 class="font-bellefair text-[5rem] text-white uppercase md:text-[7.125rem]">Space</h1>
      <p class="mx-auto max-w-lg font-barlow text-sm leading-[1.8] text-blue-300 md:text-base lg:text-lg xl:max-w-135">
        Let's face it; if you want to go to space, you might as well genuinely go to outer space and not hover kind of
        on the edge of it. Well sit back, and relax because we'll give you a truly out of this world experience!
      </p>
    </section>

    <section class="mx-auto py-30 md:pt-16 md:pb-0 xl:pt-0">
      <Link
        to={`${basePath}/destination/moon`}
        class="grid size-36 cursor-pointer place-items-center rounded-full bg-white font-bellefair text-lg text-blue-900 uppercase outline-0 outline-white/10 transition-[outline-width,scale] duration-300 ease-in-out hover:outline-88 active:scale-95 md:size-68 md:text-[2rem]"
      >
        <span>Explore</span>
      </Link>
    </section>
  </main>
</Layout>
