{
  "name": "frontendmentor",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "astro": "astro",
    "dev": "astro dev",
    "preview": "astro preview",
    "build": "pnpm check && astro build",
    "check": "astro check --tsconfig tsconfig.json",
    "lint": "eslint --fix {apps,packages,src}/**/*.{astro,ts,js}",
    "format": "prettier --write {apps,packages,src}/**/*.{astro,ts,js,css}",
    "all:run": "pnpm -r --stream --workspace-concurrency 3",
    "build:prod": "pnpm build && pnpm all:run build"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "dependencies": {
    "astro": "5.16.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@types/node": "25.0.3",
    "@typescript-eslint/eslint-plugin": "8.51.0",
    "@typescript-eslint/parser": "8.51.0",
    "eslint": "9.39.2",
    "eslint-config-love": "140.0.0",
    "eslint-plugin-astro": "1.5.0",
    "prettier": "3.7.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "shared": "workspace:*",
    "sharp": "0.34.5",
    "typescript": "5.9.3",
    "vite": "7.3.0"
  }
}